# Google Gemini API key (server-side only — never exposed to the client).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini text model id (defaults to gemini-3.5-flash).
# GEMINI_MODEL=gemini-3.5-flash

# Optional: override the Gemini Live (native audio) model id used for voice mode
# (defaults to gemini-3.1-flash-live-preview — the best free-tier audio-to-audio model).
# The server mints an ephemeral token scoped to this model; the browser connects the Live session directly.
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Optional: override the image generation model (defaults to gemini-2.5-flash-image —
# the free-tier "Nano Banana" model). Returns the image inline; we store it as a data URI.
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional: override the Veo video model (defaults to veo-3.1-fast-generate-preview).
# Video generation is asynchronous (the server polls until ready) and is PAID:
# enable billing on your Google AI Studio / Cloud account or video calls will be rejected.
# GEMINI_VIDEO_MODEL=veo-3.1-fast-generate-preview

# Where generated media (images/videos) is stored on disk and served from (/api/media/<key>).
# Defaults to ./.media. Swap the MediaStorage adapter for S3/GCS to scale beyond a single host.
# MEDIA_DIR=.media

# Postgres connection string (used at runtime and by the Prisma CLI / migrations).
# Matches the local docker compose Postgres; change it to point at your own database.
DATABASE_URL="postgresql://chat:chat@localhost:55432/chat?schema=public"

# Dedicated database the integration tests run against (created by docker compose).
TEST_DATABASE_URL="postgresql://chat:chat@localhost:55432/chat_test?schema=public"
